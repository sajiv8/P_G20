# ============================================================================
# Multi-Tenant Campus Resource Sharing Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# ============================================================================
# Firebase Configuration
# ============================================================================
FIREBASE_PROJECT_ID=university-rso
# Path to the Firebase Admin SDK service account JSON file
# In Docker: mounted at /app/config/firebase-service-account.json
# Locally:   ./config/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Firebase client-side config (used by test scripts, not by services)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=university-rso.firebaseapp.com

# ============================================================================
# Supabase Configuration
# ============================================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# Redis Configuration
# ============================================================================
# In Docker: redis://redis:6379  |  Locally: redis://localhost:6379
REDIS_URL=redis://redis:6379

# ============================================================================
# Email Provider Configuration
# ============================================================================
# Options: "resend" or "smtp"
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev

# SMTP fallback (only used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ============================================================================
# Service Ports (internal Docker network)
# ============================================================================
TENANT_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
RESOURCE_SERVICE_PORT=3003
BOOKING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ============================================================================
# Gateway Configuration
# ============================================================================
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
# Paths to Cloudflare Origin Certificate (relative to project root)
SSL_CERT_PATH=./infra/gateway/ssl/origin.pem
SSL_KEY_PATH=./infra/gateway/ssl/origin-key.pem

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info

# How often the optimization engine scans for underutilized resources (ms)
# Default: 86400000 (24 hours)
OPTIMIZATION_SCAN_INTERVAL=86400000
