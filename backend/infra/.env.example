# ============================================================================
# Multi-Tenant Campus Resource Sharing Platform — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in your secrets.
# NEVER commit the real `.env` to git.
# Paths are relative to the infra/ directory (where docker-compose.yml lives)
# ============================================================================

# ============================================================================
# Firebase Configuration
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the Firebase Admin SDK service account key JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=../config/firebase-service-account.json
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# ============================================================================
# Supabase Configuration
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://redis:6379

# ============================================================================
# Email Provider Configuration
# ============================================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# Service Ports (internal Docker network)
# ============================================================================
TENANT_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
RESOURCE_SERVICE_PORT=3003
BOOKING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ============================================================================
# Gateway Configuration
# ============================================================================
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
SSL_CERT_PATH=./gateway/ssl/origin.pem
SSL_KEY_PATH=./gateway/ssl/origin-key.pem

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info
OPTIMIZATION_SCAN_INTERVAL=86400000
